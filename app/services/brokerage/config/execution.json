{
    "default": "simulated",
    "byInstrumentType": {
        "CX": "ccxt-binance-futures",
        "EQ": "dwx",
        "FX": "dwx",
        "CFD": "dwx",
        "OPT": "optionstrat"
    },
    "bySymbol": {},
    "providers": {
        "simulated": {
            "adapter": "simulated"
        },
        "optionstrat": {
            "adapter": "optionstrat",
            "baseURL": "https://optionstrat.com/api",
            "cookie": "${ENV:OPTIONSTRAT_COOKIE}",
            "account": "${ENV:OPTIONSTRAT_ACCOUNT}",
            "timeoutMs": 10000
        },
        "j2t": {
            "adapter": "j2t",
            "baseURL": "https://api.j2t.com",
            "accountId": "${ENV:J2T_ACCOUNT_ID}",
            "accessToken": "${ENV:J2T_TOKEN}",
            "timeoutMs": 10000,
            "defaultDuration": "gtc"
        },
        "dwx": {
            "adapter": "dwx",
            "metatraderDirPath" : "${ENV:DWX_SOCKET_DIR}",
            "openOrderRetryDelayMs": 500
        },
        "ccxt-binance-futures": {
          "adapter": "ccxt",
          "exchangeId": "binance",
          "apiKey": "${ENV:BINANCE_API_KEY}",
          "secret": "${ENV:BINANCE_API_SECRET}",
          "sandbox": true,
          "enableRateLimit": true,
          "options": {
            "defaultType": "future"
          },
          "protectiveOrders": {
            "manualModificationStrategy": "adopt"
          },
          "params": {
            "recvWindow": 5000
          },
          "symbolMap": {
            "BTCUSDT": "BTC/USDT:USDT",
            "ETHUSDT": "ETH/USDT:USDT"
          }
        }
    }
}
